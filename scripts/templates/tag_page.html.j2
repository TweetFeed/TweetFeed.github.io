							<main class="docs-content">
				<div id="presentationSecondary" class="d-none d-md-block">
					<br><br><br>
					<h1 class="toph1"><i class="fas fa-tag" style="font-size: 36px;"></i> #{{ m.display_tag }}</h1>
					<h2><em>{{ m.short_subtitle }}</em></h2>
					<p style="font-size:14px;color:#737373;margin-top:0.5rem;"><a class="text-decoration-none" href="https://tweetfeed.live/rss/tag/{{ m.slug }}.xml"><i class="fas fa-rss"></i> Subscribe (RSS)</a></p>
				</div>
				<div id="presentationMobile" class="d-block d-md-none">
					<br>
					<p class="toph1"><i class="fas fa-tag" style="font-size: 36px;"></i> #{{ m.display_tag }}</p>
					<p style="font-size: 14px;"><em>{{ m.short_subtitle_mobile }}</em></p>
					<p style="font-size:13px;color:#737373;margin-top:0.25rem;"><a class="text-decoration-none" href="https://tweetfeed.live/rss/tag/{{ m.slug }}.xml"><i class="fas fa-rss"></i> Subscribe (RSS)</a></p>
				</div>
				<hr class="divider"> <!-- DIVIDER -->

				<!-- ============================================================ -->
				<!-- IOCS BY WINDOW (BAKED, NOT LIVE)                              -->
				<!-- ============================================================ -->
				<h3 class="section-heading">IOCs by window</h3>
				<div class="row">
					<div class="col-md-3 col-sm-6 col-12">
						<div class="card shadow mb-4">
							<div class="card-header text-center">
								<span class="card-text cardTitle">Today</span>
								<hr>
								<p style="font-size: 32px; font-weight: 600; color: #0026E6; margin-bottom: 0.25rem; font-family: 'Rubik', sans-serif;">{{ counts.today | format_num }}</p>
								<p style="font-size: 13px; color: #737373; margin-bottom: 0;">IOCs tagged #{{ m.display_tag }}</p>
							</div>
						</div>
					</div>
					<div class="col-md-3 col-sm-6 col-12">
						<div class="card shadow mb-4">
							<div class="card-header text-center">
								<span class="card-text cardTitle">Week</span>
								<hr>
								<p style="font-size: 32px; font-weight: 600; color: #0026E6; margin-bottom: 0.25rem; font-family: 'Rubik', sans-serif;">{{ counts.week | format_num }}</p>
								<p style="font-size: 13px; color: #737373; margin-bottom: 0;">IOCs tagged #{{ m.display_tag }}</p>
							</div>
						</div>
					</div>
					<div class="col-md-3 col-sm-6 col-12">
						<div class="card shadow mb-4">
							<div class="card-header text-center">
								<span class="card-text cardTitle">Month</span>
								<hr>
								<p style="font-size: 32px; font-weight: 600; color: #0026E6; margin-bottom: 0.25rem; font-family: 'Rubik', sans-serif;">{{ counts.month | format_num }}</p>
								<p style="font-size: 13px; color: #737373; margin-bottom: 0;">IOCs tagged #{{ m.display_tag }}</p>
							</div>
						</div>
					</div>
					<div class="col-md-3 col-sm-6 col-12">
						<div class="card shadow mb-4">
							<div class="card-header text-center">
								<span class="card-text cardTitle">Year</span>
								<hr>
								<p style="font-size: 32px; font-weight: 600; color: #0026E6; margin-bottom: 0.25rem; font-family: 'Rubik', sans-serif;">{{ counts.year | format_num }}</p>
								<p style="font-size: 13px; color: #737373; margin-bottom: 0;">IOCs tagged #{{ m.display_tag }}</p>
							</div>
						</div>
					</div>
				</div>
				<p style="color:#737373; font-size:13px; font-family:'Rubik',sans-serif; margin-top:-0.5rem; margin-bottom:1.5rem;">Counts as of {{ today_str }}. Regenerated daily.</p>

				<!-- ============================================================ -->
				<!-- ABOUT THIS TAG                                                -->
				<!-- ============================================================ -->
				<h3 class="section-heading">About #{{ m.display_tag }}</h3>
				<div class="card mb-4">
					<div class="card-body">
						<ul style="margin-bottom:0; padding-left:1.4rem; font-family:'Rubik',sans-serif; color:#1c1c1c; font-size:15px; line-height:1.8;">
							{% for b in m.bullets %}<li><b>{{ b.label }}:</b> {{ b.html | safe }}</li>
							{% endfor %}
						</ul>
					</div>
				</div>

				<!-- ============================================================ -->
				<!-- RECENT IOCS (BAKED FROM API AT BUILD TIME)                    -->
				<!-- ============================================================ -->
				<h3 class="section-heading">Recent IOCs tagged #{{ m.display_tag }}</h3>
				<div class="card mb-4">
					<div class="card-body">
						{% if samples %}
						<p style="margin-bottom:0.75rem; color:#737373; font-size:14px; font-family:'Rubik',sans-serif;">Latest {{ samples | length }} IOCs from the past 30 days. Live JSON: <a href="https://api.tweetfeed.live/v1/month/{{ m.slug }}" target="_blank" rel="noopener noreferrer"><code>api.tweetfeed.live/v1/month/{{ m.slug }}</code></a>.</p>
						<div class="table-responsive">
							<table class="table table-sm" style="table-layout:fixed; width:100%; min-width:720px; margin-bottom:0;">
								<colgroup>
									<col style="width:90px;">
									<col style="width:60px;">
									<col style="width:100%;">
									<col style="width:100px;">
								</colgroup>
								<thead>
									<tr>
										<th>Date</th>
										<th>Type</th>
										<th>Value</th>
										<th>Source</th>
									</tr>
								</thead>
								<tbody>
									{% for s in samples %}<tr>
										<td style="font-size:12px; color:#737373; vertical-align:middle; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">{{ s.date_short }}</td>
										<td style="vertical-align:middle;"><span style="font-size:11px; padding:2px 6px; background:{{ s.type_color }}; color:{{ s.type_text_color }}; border-radius:3px;">{{ s.type }}</span></td>
										<td style="font-family:monospace; font-size:13px; vertical-align:middle; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="{{ s.value_full }}"><i class="tf-copy far fa-copy" data-copy="{{ s.value_full }}" style="margin-right:0.4rem;"></i>{{ s.value_display }}</td>
										<td style="font-size:12px; vertical-align:middle; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"><a href="https://x.com/{{ s.user }}" target="_blank" rel="noopener noreferrer">@{{ s.user }}</a></td>
									</tr>
									{% endfor %}</tbody>
							</table>
						</div>
						{% if counts.month < 10 and counts.year > counts.month * 50 %}
						<p style="margin-top:0.75rem; color:#737373; font-size:13px; font-family:'Rubik',sans-serif; margin-bottom:0;"><em>Past-month volume is low; the year aggregate ({{ counts.year | format_num }}) reflects historical activity. For a longer window, query <a href="https://api.tweetfeed.live/v1/year/{{ m.slug }}" target="_blank" rel="noopener noreferrer"><code>api.tweetfeed.live/v1/year/{{ m.slug }}</code></a>.</em></p>
						{% endif %}
						{% else %}
						<p style="margin-bottom:0; color:#737373; font-size:14px; font-family:'Rubik',sans-serif;">No IOCs tagged #{{ m.display_tag }} in the past 30 days. Year aggregate: <b>{{ counts.year | format_num }}</b>. For longer-window data, query <a href="https://api.tweetfeed.live/v1/year/{{ m.slug }}" target="_blank" rel="noopener noreferrer"><code>api.tweetfeed.live/v1/year/{{ m.slug }}</code></a>.</p>
						{% endif %}
					</div>
				</div>

				<!-- ============================================================ -->
				<!-- RELATED TAGS                                                  -->
				<!-- ============================================================ -->
				<h3 class="section-heading">Related tags</h3>
				<div class="card mb-4">
					<div class="card-body">
						<p style="color:#737373; font-size:14px; font-family:'Rubik',sans-serif; margin-bottom:0.75rem;">Tags that frequently co-occur with #{{ m.display_tag }}.</p>
						<ul style="list-style:none; padding-left:0; margin-bottom:0; display:flex; flex-wrap:wrap; gap:0.5rem;">
							{% for r in m.related_tags %}<li><a class="btn btn-tf btn-sm" href="../{{ r.slug }}/">#{{ r.display }}</a></li>
							{% endfor %}</ul>
						<p style="color:#737373; font-size:13px; font-family:'Rubik',sans-serif; margin-top:1rem; margin-bottom:0;">See all tags on the <a href="../../dashboard.html" class="text-decoration-none">Dashboard</a> or browse the full <a href="../../feeds.html" class="text-decoration-none">IOC feed</a>.</p>
					</div>
				</div>

				<!-- ============================================================ -->
				<!-- FAQ                                                           -->
				<!-- ============================================================ -->
				<h3 class="section-heading">Frequently asked questions</h3>
				<section class="card mb-4">
					<div class="card-body">
						<details style="margin-bottom:0.75rem;">
							<summary style="cursor:pointer; font-weight:600; font-family:'Rubik',sans-serif; color:#1c1c1c;">{{ m.faq_q1.q }}</summary>
							<p style="margin-top:0.5rem; font-size:15px; color:#1c1c1c; font-family:'Rubik',sans-serif; line-height:1.6;">{{ m.faq_q1.a }}</p>
						</details>
						<details style="margin-bottom:0.75rem;">
							<summary style="cursor:pointer; font-weight:600; font-family:'Rubik',sans-serif; color:#1c1c1c;">{{ m.faq_q2.q }}</summary>
							<p style="margin-top:0.5rem; font-size:15px; color:#1c1c1c; font-family:'Rubik',sans-serif; line-height:1.6;">{{ m.faq_q2.a }}</p>
						</details>
						<details style="margin-bottom:0.75rem;">
							<summary style="cursor:pointer; font-weight:600; font-family:'Rubik',sans-serif; color:#1c1c1c;">How is this list updated?</summary>
							<p style="margin-top:0.5rem; font-size:15px; color:#1c1c1c; font-family:'Rubik',sans-serif; line-height:1.6;">Every 15 minutes. The TweetFeed pipeline scrapes RSS feeds from public Twitter/X security researcher accounts and lists, extracts IOCs, tags them with the relevant malware family or threat actor, and republishes the result in CSV, JSON and RSS. {{ m.license_subject }}-tagged IOCs are surfaced on this page within the next 15-minute tick. The page itself is regenerated daily by a GitHub Action.</p>
						</details>
						<details>
							<summary style="cursor:pointer; font-weight:600; font-family:'Rubik',sans-serif; color:#1c1c1c;">What is the license? Can I use this commercially?</summary>
							<p style="margin-top:0.5rem; font-size:15px; color:#1c1c1c; font-family:'Rubik',sans-serif; line-height:1.6;">All TweetFeed IOC data, including this {{ m.license_subject }} subset, is released under <b>CC0 1.0 Universal</b> (Public Domain Dedication). No attribution required, no warranty. Commercial use is allowed. The TweetFeed website code and branding are not covered by CC0.</p>
						</details>
					</div>
				</section>

				<!-- ============================================================ -->
				<!-- LICENSE                                                       -->
				<!-- ============================================================ -->
				<h3 class="section-heading">License</h3>
				<p style="color: #737373;font-size: 16px;font-family: 'Rubik', sans-serif;">
					{{ m.license_subject }} IOC data: <b>CC0 1.0 Public Domain</b>. No attribution required, no warranty. Source code for the pipeline:
					<a target="_blank" rel="noopener noreferrer" href="https://github.com/0xDanielLopez/TweetFeed">github.com/0xDanielLopez/TweetFeed</a> (MIT).
				</p>

			</div>
			<!-- End of Main Content -->

			<!-- Footer -->
			</main>
			</div>
