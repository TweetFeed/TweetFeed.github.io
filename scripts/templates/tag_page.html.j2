<!DOCTYPE html>
<html lang="en">

<head>
	<!-- 100% privacy-first analytics -->
	<script defer src="https://cloud.umami.is/script.js" data-website-id="37841dcd-5b99-4fb8-8dc8-4d40f4d38d86"></script>
	<!-- Ahrefs Web Analytics (cookieless) -->
	<script src="https://analytics.ahrefs.com/analytics.js" data-key="J59c6Ehci39jQWCQRIWuRw" async></script>
	<link rel="icon" href="/favicon.ico" type="image/x-icon">
	<meta charset="utf-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge">
	<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
	<meta name="description" content="{{ m.meta_description }}">
	<meta name="author" content="tweetfeed.live">
	<meta name="keywords" content="{{ m.meta_keywords }}">
	<link rel="canonical" href="https://tweetfeed.live/tag/{{ m.slug }}/">
	<link rel="alternate" type="application/rss+xml" title="TweetFeed - #{{ m.slug }} IOC feed" href="https://tweetfeed.live/rss/tag/{{ m.slug }}.xml">
	<title>{{ m.seo_title }}</title>
	<!-- Twitter Card -->
	<meta name="twitter:card" content="summary_large_image">
	<meta name="twitter:title" content="{{ m.twitter_title }}">
	<meta name="twitter:description" content="{{ m.twitter_description }}">
	<meta name="twitter:url" content="https://tweetfeed.live/tag/{{ m.slug }}/">
	<meta name="twitter:image" content="https://tweetfeed.live/img/TweetFeed_card_og.png">
	<meta name="twitter:creator" content="@0xDanielLopez">
	<!-- Facebook -->
	<meta property="og:url" content="https://tweetfeed.live/tag/{{ m.slug }}/">
	<meta property="og:type" content="website">
	<meta property="og:title" content="{{ m.twitter_title }}">
	<meta property="og:description" content="{{ m.twitter_description }}">
	<meta property="og:site_name" content="tweetfeed.live">
	<meta property="og:image" content="https://tweetfeed.live/img/TweetFeed_card_og.png">
	<meta property="og:image:width" content="1200">
	<meta property="og:image:height" content="627">
	<meta property="og:image:type" content="image/png">
	<meta property="og:image:alt" content="{{ m.og_image_alt }}">
	<!-- Preconnect -->
	<link rel="preconnect" href="//fonts.googleapis.com">
	<!-- Custom fonts for this template -->
	<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet" integrity="sha512-1ycn6IcaQQ40/MKBW2W4Rhis/DbILU74C1vSrLJxCq57o941Ym01SwNsOMqvEBFlcgUa6xLiPY/NS5R+E6ztJQ==" crossorigin="anonymous" referrerpolicy="no-referrer">
	<!-- Custom styles for this template -->
	<link href="../../css/sb-admin-2.min.css" rel="stylesheet">
	<!-- Custom CSS 0xDanielLopez -->
	<link href="../../css/table.css" rel="stylesheet">
	<link href="../../css/index.css" rel="stylesheet">
	<link href="../../css/tooltip.css" rel="stylesheet">
	<link href="../../css/tweetfeed.css?v=21" rel="stylesheet">
	<link href="https://fonts.googleapis.com/css2?family=Alegreya+Sans+SC&display=swap" rel="stylesheet">
	<link href="https://fonts.googleapis.com/css2?family=Rubik&display=swap" rel="stylesheet">
	<!-- Structured data -->
	<script type="application/ld+json">
	{
		"@context": "https://schema.org",
		"@type": "Organization",
		"name": "TweetFeed",
		"url": "https://tweetfeed.live/",
		"logo": "https://tweetfeed.live/img/TweetFeed_card_og.png",
		"@id": "https://tweetfeed.live/#organization",
		"founder": {"@id": "https://tweetfeed.live/#founder"},
		"sameAs": [
			"https://github.com/0xDanielLopez/TweetFeed",
			"https://phishunt.io/",
			"https://daniel.tools/",
			"https://phishunt.featurebase.app/",
			"https://www.wikidata.org/wiki/Q139589148"
		]
	}
	</script>
	<script type="application/ld+json">
	{
		"@context": "https://schema.org",
		"@type": "Person",
		"@id": "https://tweetfeed.live/#founder",
		"name": "Daniel López",
		"url": "https://tweetfeed.live/about.html",
		"image": "https://tweetfeed.live/img/TweetFeed_card_og.png",
		"jobTitle": "Cyber Threat Researcher",
		"description": "Cyber threat researcher with 10+ years in cybersecurity. Founder of TweetFeed and phishunt.io; maintainer of public Threat Intelligence feeds and MCP servers for AI agents.",
		"founderOf": {"@id": "https://tweetfeed.live/#organization"},
		"sameAs": [
			"https://github.com/0xDanielLopez",
			"https://x.com/0xDanielLopez",
			"https://daniel.tools/",
			"https://phishunt.io/",
			"https://0xdaniellopez.github.io/CV/"
		]
	}
	</script>
	<script type="application/ld+json">
	{{ webpage_jsonld | safe }}
	</script>
	<script type="application/ld+json">
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		"itemListElement": [
			{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://tweetfeed.live/"},
			{"@type": "ListItem", "position": 2, "name": "#{{ m.display_tag }}", "item": "https://tweetfeed.live/tag/{{ m.slug }}/"}
		]
	}
	</script>
	<script type="application/ld+json">
	{{ faq_jsonld | safe }}
	</script>
</head>

