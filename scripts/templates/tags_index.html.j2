					<p style="font-size: 14px;"><em>{{ tag_count }} curated tag landing pages</em></p>
				</div>
				<hr class="divider">

				{% for cat in categories %}
				<h3 class="section-heading">{{ cat.heading }} <span style="font-size:14px; color:#737373; font-weight:400;">&middot; {{ cat.tags | length }}</span></h3>
				<div class="card mb-4">
					<div class="card-body">
						<p style="margin-bottom:0.9rem; color:#737373; font-size:14px; font-family:'Rubik',sans-serif;">{{ cat.blurb }}</p>
						<div class="row">
							{% for t in cat.tags %}
							<div class="col-md-6 col-12" style="margin-bottom:0.7rem;">
								<a href="../tag/{{ t.slug }}/" class="text-decoration-none" style="display:block; padding:0.5rem 0.7rem; border:1px solid #1c1c1c; border-radius:0; background:#fff;">
									<div style="display:flex; justify-content:space-between; align-items:baseline; gap:0.6rem;">
										<span style="font-family:'Rubik',sans-serif; font-weight:600; color:#1c1c1c;">#{{ t.display_tag }}</span>
										<span style="font-size:11px; color:#737373; font-family:'Rubik',sans-serif; white-space:nowrap;">{{ t.year_count }} year &middot; {{ t.month_count }} month</span>
									</div>
									<div style="font-size:12px; color:#737373; font-family:'Rubik',sans-serif; line-height:1.4; margin-top:0.15rem;">{{ t.subtitle }}</div>
								</a>
							</div>
							{% endfor %}
						</div>
					</div>
				</div>
				{% endfor %}

				<h3 class="section-heading">Other reference</h3>
				<div class="card mb-4">
					<div class="card-body">
						<p style="margin-bottom:0; color:#1c1c1c; font-size:15px; font-family:'Rubik',sans-serif; line-height:1.7;">
							<a href="../ioc-types/" class="text-decoration-none"><b>IOC types</b></a> &middot; the 5 type-specific hubs (URLs / domains / IPs / MD5 / SHA-256). <br>
							<a href="../threat-intelligence-guide.html" class="text-decoration-none"><b>Threat Intelligence guide</b></a> &middot; ~1,640-word pillar covering IOC types, OSINT vs commercial, MITRE ATT&amp;CK basics, glossary.
