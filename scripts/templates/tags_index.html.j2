		"url": "https://tweetfeed.live/tags/",
		"description": "Index of all {{ tag_count }} tag landing pages on TweetFeed.",
		"isPartOf": {"@id": "https://tweetfeed.live/#organization"},
		"inLanguage": "en",
		"mainEntity": {
			"@type": "ItemList",
			"numberOfItems": {{ tag_count }},
